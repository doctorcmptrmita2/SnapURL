# ── Paste these into Dokploy → your Compose service → Environment ──
# Generate APP_KEY locally with: php artisan key:generate --show

APP_NAME=SnapURL
APP_ENV=production
APP_KEY=base64:GENERATE_ME
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Database — host MUST be the compose service name `db`
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=snapurl
DB_USERNAME=snapurl
DB_PASSWORD=CHANGE_ME_STRONG
DB_ROOT_PASSWORD=CHANGE_ME_ROOT

# Redis — host MUST be the compose service name `redis`
REDIS_HOST=redis
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Mail (optional)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=info@your-domain.com
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="info@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
